RewriteEngine On
# Developed By @radiumsahil
# If the request is not a directory
RewriteCond %{REQUEST_FILENAME} !-d
# And if the corresponding .php file exists
RewriteCond %{REQUEST_FILENAME}.php -f
# Rewrite the URL to add .php extension
RewriteRule ^([^\.]+)$ $1.php [NC,L]
# Enable custom error pages
ErrorDocument 404 /404.php

<Files "sms-usa.js">
    Header set Access-Control-Allow-Origin "https://otpsuite.com"
</Files>

<Files "sms-int-1.js">
    Header set Access-Control-Allow-Origin "https://otpsuite.com"
</Files>

<Files "sms-int-2.js">
    Header set Access-Control-Allow-Origin "https://otpsuite.com"
</Files>

<Files "boost-socials.js">
    Header set Access-Control-Allow-Origin "https://otpsuite.com"
</Files>

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php81” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php81___lsphp .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
